# Public Keyzori server origin. Use HTTPS outside loopback.
KEYZORI_SERVER_URL=https://licenses.example.com

# Dashboard login password. Generate a unique value with at least 16 characters.
KEYZORI_AUTH_PASS=replace_with_a_unique_dashboard_password

# Server ADMIN_API_KEY. Keep this different from KEYZORI_AUTH_PASS.
KEYZORI_ADMIN_KEY=replace_with_the_server_admin_key_of_32_or_more_characters

HOST=0.0.0.0
PORT=3100
KEYZORI_SECURE_COOKIES=true
KEYZORI_SESSION_TTL_MINUTES=480
KEYZORI_UPSTREAM_TIMEOUT_MS=10000

# Only for an HTTP server reachable over a trusted private network.
# KEYZORI_ALLOW_INSECURE_SERVER=true
