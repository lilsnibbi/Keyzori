# Application Port
PORT=3000
HOST=0.0.0.0

# PostgreSQL Database URL for Drizzle ORM
DATABASE_URL=postgresql://user:password@localhost:5432/keyzori

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Secure API Key for remote HTTP admin endpoints
ADMIN_API_KEY=replace_with_at_least_32_random_characters
# Optional comma-separated previous keys for zero-downtime rotation.
# ADMIN_API_KEYS=previous_random_admin_secret

# Only enable when direct access is blocked and requests come through a trusted proxy.
TRUST_PROXY_HEADERS=false
# Required when proxy headers are enabled. Comma-separated immediate-proxy CIDRs.
# TRUSTED_PROXY_CIDRS=10.0.0.0/8,2001:db8::/32

# Set false to disable the Scalar UI and generated OpenAPI document.
OPENAPI_ENABLED=true

# Per-client request budget and maximum JSON request size.
RATE_LIMIT_PER_MINUTE=60
MAX_REQUEST_BODY_BYTES=65536
