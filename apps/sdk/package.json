{
	"name": "keyzori",
	"version": "0.2.1-test.2",
	"license": "Apache-2.0",
	"description": "Typed SDK for integrating applications with a Keyzori License Server.",
	"author": "Keyzori contributors",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lilsnibbi/Keyzori.git",
		"directory": "apps/sdk"
	},
	"keywords": [
		"keyzori",
		"licensing",
		"sdk",
		"hardware-id"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"type": "module",
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.3.14"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"NOTICE"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node && bunx tsc",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit",
		"prepack": "bun run build",
		"publish:package": "bun publish --access public --tolerate-republish"
	}
}
